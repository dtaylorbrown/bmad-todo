# syntax=docker/dockerfile:1

ARG VITE_API_URL=http://localhost:3001

FROM node:20-bookworm AS builder

ARG VITE_API_URL
ENV VITE_API_URL=${VITE_API_URL}

RUN corepack enable && corepack prepare pnpm@10.8.1 --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/shared/package.json ./packages/shared/
COPY apps/web/package.json ./apps/web/
COPY apps/api/package.json ./apps/api/

RUN pnpm install --frozen-lockfile

COPY packages/shared ./packages/shared
COPY apps/web ./apps/web

RUN pnpm --filter @bmad-todo/shared build \
  && pnpm --filter web build \
  && test -f apps/web/dist/index.html

FROM nginx:1.27-alpine AS runner

# The default /docker-entrypoint.sh always runs /docker-entrypoint.d/ (including
# envsubst on templates), which regenerates conf.d/default.conf at container start.
# Skip that entirely so our config and static files stay on disk.
RUN rm -rf /etc/nginx/templates /usr/share/nginx/html/*

COPY docker/nginx-web.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/apps/web/dist/ /usr/share/nginx/html/

RUN test -s /usr/share/nginx/html/index.html

EXPOSE 8080

ENTRYPOINT ["nginx"]
CMD ["-g", "daemon off;"]
